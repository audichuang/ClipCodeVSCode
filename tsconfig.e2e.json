{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2022",
    "lib": ["ES2022"],
    "outDir": "out-e2e",
    "rootDir": "test-e2e",
    "strict": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "types": ["node", "mocha", "vscode"]
  },
  "include": ["test-e2e/**/*.ts"]
}
